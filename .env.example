# ImportYeti credentials (free account)
IMPORTYETI_EMAIL=your_email@example.com
IMPORTYETI_PASSWORD=your_password

# Proxy (optional, needed for Alibaba/IndiaMart at scale)
PROXY_URL=

# Database
DB_PATH=data/trust_engine.duckdb

# Scraper settings
MAX_CONCURRENT_REQUESTS=5
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0
HEADLESS=true

# Phase 4 Security
API_KEY=dev-trust-key-99
